{
  "name": "grpc-ui",
  "productName": "grpc-ui",
  "version": "0.1.3",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron \"vite\" \"wait-on tcp:5173 && tsc -p tsconfig.main.json && electron .\"",
    "build": "vite build && tsc -p tsconfig.main.json && rm -rf dist/proto && cp -r src/proto dist/proto && rm -rf dist/assets && cp -r src/assets dist/assets",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "dump-storage": "node scripts/dump-storage.js",
    "e2e": "npm run build && playwright test",
    "e2e:ui": "npm run build && playwright test --ui",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "release": "npm run build && electron-builder --publish always",
    "bump:patch": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version",
    "bump:major": "npm version major --no-git-tag-version"
  },
  "keywords": [],
  "author": {
    "name": "Huan Min Gan",
    "email": "ganhuanmin@gmail.com"
  },
  "license": "ISC",
  "description": "gRPC UI client — like Insomnia/Postman for gRPC",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.96.1",
    "electron-updater": "^6.8.3",
    "protobufjs": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "build": {
    "appId": "com.grpcui.app",
    "productName": "gRPC UI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "src/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "src/assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "classic-level": "^3.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.1"
  }
}
